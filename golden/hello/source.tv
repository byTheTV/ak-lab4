; Базовый пример: вывод строки с помощью pstr
; Используем строковый литерал "Hi\n" и функцию для его вывода

(defun emit-ch-at (base idx)
  (out (load (+ (+ base 1) idx))))

(defun emit-pstr-rec (base idx)
  (if (< idx (load base))
      (progn
        (emit-ch-at base idx)
        (emit-pstr-rec base (+ idx 1)))
      0))

(defun emit-pstr (base)
  (emit-pstr-rec base 0))

; Выводим строку "Hi\n"
(emit-pstr "Hi\n")
